// Test: Enum and Pattern Matching
print("=== Enum Tests ===")

enum Color {
    Red,
    Green,
    Blue,
    Custom(int, int, int)
}

print("Color.Red:")
print(Color.Red)

let c = Color.Custom(10, 20, 30)
print("\nColor.Custom(10, 20, 30):")
print(c)

print("\nMatch Statement:")
fn describeColor(color: Color) {
    match color {
        Red => { print("It's red!") }
        Green => { print("It's green!") }
        Blue => { print("It's blue!") }
        Custom(r, g, b) => {
            print("It's custom!")
            print("R: " + toString(r))
            print("G: " + toString(g))
            print("B: " + toString(b))
        }
    }
}

describeColor(Color.Red)
describeColor(c)

print("\nMatch Expression:")
fn colorName(color: Color) -> string {
    match color {
        Red => { return "Red" }
        Green => { return "Green" }
        Blue => { return "Blue" }
        Custom(_, _, _) => { return "Custom" }
        _ => { return "Unknown" }
    }
}

print(colorName(Color.Green))
print(colorName(Color.Custom(0, 0, 0)))

print("\nTests complete!")
