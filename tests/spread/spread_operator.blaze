// Test: Spread Operator
// Tests the spread operator (...) for arrays

// Test 1: Basic array concatenation
let arr1 = [1, 2, 3]
let arr2 = [4, 5, 6]
let combined = [...arr1, ...arr2]
print(combined)  // Expected: [1, 2, 3, 4, 5, 6]

// Test 2: Mix of elements and spreads
let mixed = [0, ...arr1, 10, ...arr2, 20]
print(mixed)  // Expected: [0, 1, 2, 3, 10, 4, 5, 6, 20]

// Test 3: Copying an array
let copy = [...arr1]
print(copy)  // Expected: [1, 2, 3]

// Test 4: Empty array with spread
let empty: [int] = []
let withEmpty = [...empty, 1, 2]
print(withEmpty)  // Expected: [1, 2]

// Test 5: Multiple consecutive spreads
let a = [1]
let b = [2]
let c = [3]
let abc = [...a, ...b, ...c]
print(abc)  // Expected: [1, 2, 3]

// Test 6: Spread at different positions
let base = [5, 6]
let extended = [...base, 7]
print(extended)  // Expected: [5, 6, 7]
let prepended = [4, ...base]
print(prepended)  // Expected: [4, 5, 6]

// Test 7: Single spread only
let original = [10, 20, 30]
let onlySpread = [...original]
print(onlySpread)  // Expected: [10, 20, 30]

// Test 8: Nested arrays
let nested1 = [[1, 2], [3, 4]]
let nested2 = [[5, 6]]
let nestedCombined = [...nested1, ...nested2]
print(nestedCombined)  // Expected: [[1, 2], [3, 4], [5, 6]]

// Test 9: String arrays
let strings1 = ["hello", "world"]
let strings2 = ["foo", "bar"]
let allStrings = [...strings1, ...strings2]
print(allStrings)  // Expected: [hello, world, foo, bar]

// Test 10: Spread with function result
fn getArray() -> [int] {
    return [100, 200]
}
let fromFunc = [...getArray(), 300]
print(fromFunc)  // Expected: [100, 200, 300]
