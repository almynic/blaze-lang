let m = hashMap()
hashMapSet(m, "a", 1)
hashMapSet(m, "b", 2)
hashMapSet(m, 10, 99)

print(hashMapHas(m, "a"))
print(hashMapGet(m, "b"))
print(hashMapGet(m, 10))
print(hashMapSize(m))

hashMapSet(m, "b", 20)
print(hashMapGet(m, "b"))
print(hashMapDelete(m, "a"))
print(hashMapDelete(m, "missing"))
print(hashMapSize(m))
print(len(hashMapKeys(m)))
print(len(hashMapValues(m)))

hashMapClear(m)
print(hashMapSize(m))

let s = hashSet()
hashSetAdd(s, "x")
hashSetAdd(s, "x")
hashSetAdd(s, 42)
print(hashSetHas(s, "x"))
print(hashSetHas(s, 42))
print(hashSetSize(s))
print(hashSetDelete(s, "x"))
print(hashSetDelete(s, "x"))
print(hashSetSize(s))
print(len(hashSetValues(s)))
