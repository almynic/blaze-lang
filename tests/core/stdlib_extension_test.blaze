// prelude: extended std/math, std/string, std/array
print(clamp(100, 0, 10))
print(ceilDiv(7, 3))
print(floorDiv(-7, 3))

let s: string = "pre-hello"
print(trimPrefix(s, "pre-"))
print(trimSuffix("name.txt", ".txt"))

let block: string = "x
y
z"
print(len(lines(block)))

let xs: [int] = [1, 2]
extend(xs, [3, 4])
print(len(xs))

print(pow(2, 8))
print(mod(-1, 5))

let ys: [int] = prepend(0, [1, 2])
print(len(ys))
print(len(rest(ys)))
print(len(allButLast([1, 2, 3])))

let z: [int] = intersperse([1, 2, 3], 0)
print(len(z))

print(orEmpty("", "nil"))
print(joinLines(["a", "b"]))
print(minOf(3, 5))
print(maxOf(2.5, 1.0))
print(clamp(12, 0, 10))
